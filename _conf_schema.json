          "chat": { "description": "对话模型", "type": "string", "default": "gpt-3.5-turbo" },
          "vision": { "description": "视觉模型", "type": "string", "default": "gpt-3.5-turbo" },
          "fast": { "description": "快速模型", "type": "string", "default": "gpt-3.5-turbo" },
